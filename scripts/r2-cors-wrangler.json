{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://grandeflix.com",
          "https://www.grandeflix.com",
          "http://localhost:3000"
        ],
        "methods": ["PUT", "GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
