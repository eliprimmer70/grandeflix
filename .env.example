# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://psicdsfgkqhjvqreroxj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-key

# Production: https://grandeflix.com | Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: auto-promote one email to admin (server-only, not exposed to the browser).
# ADMIN_BOOTSTRAP_EMAIL=eli.primmer@gmail.com

# Required for admin media uploads (server-only — never NEXT_PUBLIC).
# Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# Cloudflare R2 for large video uploads (server-only — never NEXT_PUBLIC).
# See README → "Cloudflare R2" for dashboard setup steps.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=grandeflix-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# NOTE: Never put service_role or R2 secrets in NEXT_PUBLIC_* or commit them to git.
